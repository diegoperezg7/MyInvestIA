# InvestIA - Environment Variables
# Copy this file to .env and fill in your values

# Supabase (PostgreSQL database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Telegram Bot (alerts & notifications)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Mistral AI (reasoning, chat, sentiment analysis)
MISTRAL_API_KEY=your-mistral-api-key

# NewsAPI.org (optional, free tier: 100 req/day for aggregated news)
NEWSAPI_KEY=

# Market data providers (optional fallbacks - Yahoo Finance works without keys)
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
TWELVEDATA_API_KEY=

# OpenClaw (self-hosted AI agent for Telegram alerts)
OPENCLAW_ENABLED=true
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=your-openclaw-hooks-token

# Display currency (default: USD)
DISPLAY_CURRENCY=USD

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# App settings
DEBUG=false
