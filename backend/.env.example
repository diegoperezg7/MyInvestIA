# InvestIA - Environment Variables
# Copy this file to .env and fill in your values

# Supabase (PostgreSQL database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Telegram Bot (alerts & notifications)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# AI providers
CEREBRAS_API_KEY=
GROQ_API_KEY=

# NewsAPI.org (optional, free tier: 100 req/day for aggregated news)
NEWSAPI_KEY=
NEWS_MIXED_MODE=true
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=InvestIA/1.0

# Market data providers (optional fallbacks - Yahoo Finance works without keys)
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
TWELVEDATA_API_KEY=
BLOOMBERG_ENABLED=false
BLOOMBERG_HOST=localhost
BLOOMBERG_PORT=8194
MARKET_PROVIDER_ORDER=yfinance,alphavantage,finnhub,twelvedata,bloomberg
CRYPTO_PROVIDER_ORDER=coingecko,yfinance
MACRO_PROVIDER_ORDER=fred,yfinance
FUNDAMENTALS_PROVIDER_ORDER=yfinance
FILINGS_PROVIDER_ORDER=sec
NEWS_PROVIDER_ORDER=gdelt,rss,finnhub,reddit,stocktwits,newsapi,twitter

# Official data sources
FRED_API_KEY=
BLS_API_KEY=
SEC_USER_AGENT=InvestIA/1.0 contact: support@example.com
WORLDBANK_COUNTRY=WLD

# OpenClaw (self-hosted AI agent for Telegram alerts)
OPENCLAW_ENABLED=true
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=your-openclaw-hooks-token

# Display currency (default: USD)
DISPLAY_CURRENCY=USD
SCORE_WEIGHT_FUNDAMENTALS=0.25
SCORE_WEIGHT_TECHNICAL=0.25
SCORE_WEIGHT_SENTIMENT=0.15
SCORE_WEIGHT_MACRO=0.15
SCORE_WEIGHT_PORTFOLIO_FIT=0.20
PORTFOLIO_CANDIDATE_WEIGHT=0.10
SENTIMENT_DECAY_HALF_LIFE_HOURS=18
SENTIMENT_NOISE_CONFIDENCE_THRESHOLD=0.35
SENTIMENT_FINBERT_ENABLED=false

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# External Connections
# Fernet key for encrypting API credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_MASTER_KEY=
# Moralis API key (for wallet tracking - MetaMask, etc.)
MORALIS_API_KEY=
# eToro API credentials (limited access)
ETORO_API_KEY=
ETORO_API_SECRET=
# Polymarket API key
POLYMARKET_API_KEY=

# App settings
DEBUG=false
CORS_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost
PORTAL_URL=https://portal.your-domain.com

# Shared identity (AIdentity)
AIDENTITY_URL=https://aidentity.your-domain.com/api/v1
AIDENTITY_SECRET=
