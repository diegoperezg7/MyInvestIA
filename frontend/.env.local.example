# Leave empty when the frontend reaches the API through the same HTTPS origin
# (for example behind Caddy, Nginx or Cloudflare). Only set a full URL for
# local direct-to-backend development.
NEXT_PUBLIC_API_URL=

# Portal URL for navigation links (e.g. https://portal.your-domain.com)
NEXT_PUBLIC_PORTAL_URL=

# Cookie domain for cross-app SSO (e.g. .your-domain.com). Leave empty for localhost.
NEXT_PUBLIC_COOKIE_DOMAIN=
